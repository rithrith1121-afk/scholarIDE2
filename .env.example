# GROQ_API_KEY: Required for Groq AI API calls (Problem generation, Help).
VITE_GROQ_API_KEY="your_groq_api_key"

# JUDGE0_URL: The URL for the Judge0 API.
# Default is 'https://ce.judge0.com' (Community Edition)
VITE_JUDGE0_URL="https://ce.judge0.com"

# JUDGE0_API_KEY: Optional. Required if using RapidAPI.
VITE_JUDGE0_API_KEY=""
